# Supabase (https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only: seed script, /api/kognitos/* routes — never expose in the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Kognitos API (used by POST /api/kognitos/sync, discover, etc. — required on Vercel for onboarding)
KOGNITOS_BASE_URL=https://app.us-1.kognitos.com
# Optional: web app origin for automation detail links in the UI. If unset, derived from KOGNITOS_BASE_URL (api.* → app.*).
# KOGNITOS_APP_BASE_URL=https://app.us-1.stg.kognitos.com
# Use either API key or PAT (same check as code: KOGNITOS_API_KEY || KOGNITOS_PAT)
KOGNITOS_API_KEY=
# KOGNITOS_PAT=
# Use either organization id name (KOGNITOS_ORGANIZATION_ID || KOGNITOS_ORG_ID)
KOGNITOS_ORGANIZATION_ID=
# KOGNITOS_ORG_ID=
KOGNITOS_WORKSPACE_ID=
# Optional: bootstraps one registered automation at runtime (skips onboarding dialog when unset would block)
KOGNITOS_AUTOMATION_ID=
# Optional: force agent id for exception reply (Create Event) when discovery APIs return 403 or fail
# KOGNITOS_EXCEPTION_AGENT_ID=astral